{
  "expo": {
    "name": "Tide",
    "slug": "tide-notes",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "icon": "./logo/2.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#edf0f6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./logo/2.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./logo/2.png",
        "backgroundColor": "#edf0f6"
      }
    },
    "scheme": "tide",
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./logo/2.png"
    },
    "plugins": [
      [
        "expo-sqlite"
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Tide to attach photos to notes."
        }
      ],
      "expo-asset",
      "expo-web-browser"
    ]
  }
}
